rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isKnownSubcollection(collectionName) {
      return collectionName in [
        'patients',
        'records',
        'appointments',
        'clinicalEntries',
        'professionals',
        'auditLogs'
      ];
    }

    function userEditableProfileFields() {
      return [
        'email',
        'mustChangePassword',
        'providerId',
        'schemaVersion',
        'updatedAt'
      ];
    }

    function onlyUserEditableProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(userEditableProfileFields())
        && request.resource.data.diff(resource.data).addedKeys().hasOnly(userEditableProfileFields())
        && request.resource.data.diff(resource.data).removedKeys().hasOnly([]);
    }

    // Perfis individuais de usuario (metadados e configuracoes)
    match /users/{uid} {
      allow get: if ownsUserDoc(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if ownsUserDoc(uid) || isAdmin();
      allow update: if isAdmin() || (ownsUserDoc(uid) && onlyUserEditableProfileFieldsChanged());
      allow delete: if false;
    }

    // Indice minimo para permitir login por CPF.
    // O documento e buscado pelo CPF digitado e retorna apenas o e-mail de autenticacao.
    match /loginIdentifiers/{cpfDigits} {
      allow get: if true;
      allow list: if false;
      allow create, update: if isAdmin();
      allow update: if signedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Dados compartilhados da unidade (pacientes, prontuarios, etc)
    match /{collectionName}/{docId} {
      allow read, write: if signedIn() 
        && isKnownSubcollection(collectionName)
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
