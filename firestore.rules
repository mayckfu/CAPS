rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isKnownSubcollection(collectionName) {
      return collectionName in [
        'patients',
        'records',
        'appointments',
        'clinicalEntries',
        'professionals',
        'auditLogs'
      ];
    }

    // Perfis individuais de usuario (metadados e configuracoes)
    match /users/{uid} {
      allow get: if ownsUserDoc(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if ownsUserDoc(uid) || isAdmin();
      allow delete: if false;
    }

    // Dados compartilhados da unidade (pacientes, prontuarios, etc)
    match /{collectionName}/{docId} {
      allow read, write: if signedIn() 
        && isKnownSubcollection(collectionName)
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
